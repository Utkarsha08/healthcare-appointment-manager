generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  name          String
  role          Role
  dateOfBirth   DateTime?
  gender        String?
  phone         String?
  bloodGroup    String?
  address       String?
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt     DateTime      @default(now())
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  googleCalendarId   String?
  googleEmail        String?
  appointments  Appointment[] @relation("PatientAppointments")
  doctorProfile Doctor?
}

model Doctor {
  id              String        @id @default(cuid())
  userId          String        @unique
  specialisation  String
  qualification   String?
  experienceYears Int?
  consultationFee Int?
  phone           String?
  about           String?
  slotDurationMin Int           @default(20)
  workingHours    Json
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  googleCalendarId   String?
  googleEmail        String?
  appointments    Appointment[]
  user            User          @relation(fields: [userId], references: [id])
  leaveDays       LeaveDay[]
}

model LeaveDay {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, date])
}

model Appointment {
  id                   String            @id @default(cuid())
  patientId            String
  doctorId             String
  slotStart            DateTime
  slotEnd              DateTime
  status               AppointmentStatus @default(HELD)
  holdExpiresAt        DateTime?
  symptoms             String?
  preVisitSummary      Json?
  doctorNotes          String?
  prescription         Json?
  postVisitSummary     String?
  googleEventIdPatient String?
  googleEventIdDoctor  String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  doctor               Doctor            @relation(fields: [doctorId], references: [id])
  patient              User              @relation("PatientAppointments", fields: [patientId], references: [id])
  notifications        Notification[]

  @@unique([doctorId, slotStart])
}

model Notification {
  id            String             @id @default(cuid())
  appointmentId String
  type          String
  recipient     String
  status        NotificationStatus @default(PENDING)
  attempts      Int                @default(0)
  lastError     String?
  createdAt     DateTime           @default(now())
  appointment   Appointment        @relation(fields: [appointmentId], references: [id])
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  HELD
  CONFIRMED
  CANCELLED
  COMPLETED
  LEAVE_CANCELLED
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model BackgroundJob {
  id          String   @id @default(cuid())
  type        String   // "EMAIL_RETRY", "APPOINTMENT_REMINDER", "MEDICATION_REMINDER"
  payload     Json     // Job specific data
  status      JobStatus @default(PENDING)
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  executeAt   DateTime @default(now())
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum JobStatus {
  PENDING
  COMPLETED
  FAILED
}
